{
    "name": "saha-care",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "emulators": "firebase emulators:start",
        "dev:emulators": "concurrently \"npm run emulators\" \"npm run dev\"",
        "generate:icons": "npx tsx scripts/generateIcons.ts",
        "seed:cases": "npx tsx scripts/seedCaseDefinitions.ts",
        "seed:reports": "npx tsx scripts/seedReports.ts",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.8",
        "@mui/material": "^7.3.8",
        "firebase": "^12.9.0",
        "leaflet": "^1.9.4",
        "leaflet.heat": "^0.2.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-leaflet": "^5.0.0",
        "react-leaflet-cluster": "^4.0.0",
        "react-router-dom": "^7.13.1",
        "recharts": "^3.7.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/leaflet": "^1.9.21",
        "@types/node": "^25.3.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/coverage-v8": "^4.0.18",
        "concurrently": "^9.1.2",
        "dotenv": "^17.3.1",
        "eslint": "^10.0.2",
        "firebase-admin": "^13.7.0",
        "jsdom": "^28.1.0",
        "sharp": "^0.34.5",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.0.18"
    }
}
